# ---------------------------------------------------------------------------
# CDG Builder — variáveis de ambiente (exemplo).
# Copie para .env.local e substitua os placeholders.
# NUNCA commitar .env.local (já está no .gitignore).
# ---------------------------------------------------------------------------

# Supabase Postgres — dashboard > Project Settings > Database > Connection string
# - DATABASE_URL: transaction pooler (porta 6543, pgbouncer=true). Usado em runtime.
# - DIRECT_URL: conexão direta (porta 5432). Usado pelo Prisma migrate.
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# Auth.js v5 — segredo usado para assinar/verificar cookies de sessão.
# Gere com: `openssl rand -base64 32` ou https://generate-secret.vercel.app/32
AUTH_SECRET="gere-um-valor-aleatorio-de-32-bytes"

# Resend — magic-link por email. https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Remetente dos emails. Em dev/teste use `onboarding@resend.dev` (só manda para
# emails verificados na conta Resend). Em produção, comprar+verificar domínio
# próprio (Fase 7).
EMAIL_FROM="onboarding@resend.dev"

# URL pública do app. Em dev: http://localhost:3000. Em Vercel, definido
# automaticamente pela plataforma (deixe em branco/sobrescreva via dashboard).
NEXTAUTH_URL="http://localhost:3000"
